# ===== 讯飞星火大模型配置 =====
# 从讯飞开放平台 (https://xinghuo.xfyun.cn/) 获取 API Key
# 创建应用后，在"服务接口认证信息"中获取 APIKey
SPARK_API_KEY=your-spark-api-key-here
SPARK_API_BASE=https://spark-api-open.xf-yun.com/v1
SPARK_CHAT_MODEL=generalv3.5
SPARK_EMBEDDING_MODEL=generalv3.5
SPARK_MAX_TOKENS=4096
SPARK_TEMPERATURE=0.7

# ===== Neo4j 图数据库 =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kg_password_2024

# ===== ChromaDB 向量数据库 =====
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ===== 应用配置 =====
APP_HOST=localhost
APP_PORT=8501
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ===== 数据采集配置 =====
DATA_UPDATE_INTERVAL_HOURS=24
MAX_CRAWL_PAGES=50
REQUEST_DELAY_SECONDS=1.5

# Playwright 浏览器爬虫开关（先运行: playwright install chromium）
DATA_ENABLE_PLAYWRIGHT=false

# 搜索 API 密钥（可选）
DATA_SERPAPI_API_KEY=
DATA_BING_API_KEY=
