APP_NAME=CompetencyGraph
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=competency_graph

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_SKILL=skill_index
ES_INDEX_JD=jd_index

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# 讯飞星火
SPARK_APP_ID=your_app_id
SPARK_API_KEY=your_api_key
SPARK_API_SECRET=your_api_secret
SPARK_DOMAIN=4.0Ultra
SPARK_WS_URL=wss://spark-api.xf-yun.com/v4.0/chat

# 业务配置
SKILL_DICT_PATH=./data/skill_dictionary.json
SIMHASH_THRESHOLD=0.85
CONFIDENCE_THRESHOLD=0.7
HIGH_CONFIDENCE_SOURCES=5
STALE_JD_YEARS=2

# 匹配权重
W_REQUIRED=0.4
W_PREFERRED=0.2
W_DEPTH=0.25
W_DOMAIN=0.15
